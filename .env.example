# === Kotaemon sur Railway ===
# Copier en .env et remplir les valeurs
# Ne jamais commiter le fichier .env avec de vraies cles API !

# --- API Security ---
# Set a strong random secret to protect /api/ingest and /api/chat
# When set, requests must include header: X-Api-Key: <your-secret>
# API_SECRET_KEY=change-me-to-a-strong-random-secret

# --- Gradio ---
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# --- Google Gemini (par defaut si OPENAI_API_KEY n'est pas defini) ---
GOOGLE_API_KEY=
# Modeles par defaut : gemini-1.5-flash / text-embedding-004
# Decommenter pour changer :
# GOOGLE_CHAT_MODEL=gemini-2.0-flash
# GOOGLE_EMBEDDINGS_MODEL=models/text-embedding-004

# --- OpenAI (optionnel — si defini, OpenAI devient le provider par defaut) ---
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1

# --- Azure OpenAI (optionnel) ---
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small

# --- Anthropic (optionnel) ---
# ANTHROPIC_API_KEY=

# --- GraphRAG ---
USE_NANO_GRAPHRAG=false
USE_MS_GRAPHRAG=true
USE_LIGHTRAG=true

# --- Upload / Ingest limits ---
# KH_UPLOAD_DIR=/app/ktem_app_data/user_data/files
# MAX_UPLOAD_SIZE and MAX_EXTRACT_SIZE are set in api_ingest.py (150MB / 100MB)
