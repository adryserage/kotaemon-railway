# === Kotaemon sur Railway ===
# Copier en .env et remplir les valeurs

# --- Gradio ---
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# --- Google Gemini (par défaut si OPENAI_API_KEY n'est pas défini) ---
GOOGLE_API_KEY=
# Modèles par défaut : gemini-1.5-flash / text-embedding-004
# Décommenter pour changer :
# GOOGLE_CHAT_MODEL=gemini-2.0-flash
# GOOGLE_EMBEDDINGS_MODEL=models/text-embedding-004

# --- OpenAI (optionnel — si défini, OpenAI devient le provider par défaut) ---
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1

# --- Azure OpenAI (optionnel) ---
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small

# --- Anthropic (optionnel) ---
# ANTHROPIC_API_KEY=

# --- GraphRAG ---
USE_NANO_GRAPHRAG=true
